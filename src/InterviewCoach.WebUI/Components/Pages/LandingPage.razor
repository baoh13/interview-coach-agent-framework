@* Generated by GitHub Copilot on 2026-03-15 *@
@page "/"
@using InterviewCoach.WebUI.Components.Pages.Chat
@using InterviewCoach.WebUI.Services
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Bespoke Software Solutions - Interview Coach</PageTitle>

<div class="landing-container">
    <section id="hero" class="hero-section" aria-labelledby="hero-headline">
        <div class="hero-inner">
            <div class="hero-left reveal-item" style="--reveal-delay: 0ms">
                <h1 id="hero-headline" class="hero-headline">
                    @(siteProps?.Name ?? "Bespoke Software Solutions")
                </h1>
                <p class="hero-sub">
                    Tailored software consulting for your unique business needs.
                </p>
                <div class="hero-ctas">
                    <a href="#contact" class="btn btn-primary">Get in Touch</a>
                    <a href="#services" class="btn btn-secondary">Our Services</a>
                </div>
            </div>

            <div class="hero-right" aria-hidden="true">
                <div class="value-chip reveal-item" style="--reveal-delay: 160ms">
                    Generative AI integrated from day one
                </div>
                <div class="value-chip reveal-item" style="--reveal-delay: 240ms">
                    Over a decade of cross-industry experience
                </div>
                <div class="value-chip reveal-item" style="--reveal-delay: 320ms">
                    Cloud-native and scalable by default
                </div>
            </div>

            <div class="hero-accent-rule" aria-hidden="true"></div>
        </div>
    </section>

    <section id="services" class="services-section" aria-labelledby="services-heading">
        <div class="section-inner">
            <h2 id="services-heading" class="section-title reveal-item" style="--reveal-delay: 0ms">
                Our Services
            </h2>

            @if (servicesData?.Cards is { Length: > 0 })
            {
                <ul class="services-grid" role="list">
                    @foreach (var (card, index) in servicesData.Cards.Select((c, i) => (c, i)))
                    {
                        <li class="service-card reveal-item" style="--reveal-delay: @((index + 1) * 80)ms">
                            <span class="service-icon" aria-hidden="true">@card.Icon</span>
                            <h3 class="service-name">@card.Name</h3>
                            <p class="service-description">@card.Description</p>
                        </li>
                    }
                </ul>
            }
        </div>
    </section>

    <section id="how-we-work" class="process-section" aria-labelledby="process-heading">
        <div class="section-inner">
            <h2 id="process-heading" class="section-title reveal-item" style="--reveal-delay: 0ms">
                How We Work
            </h2>

            <ol class="process-steps" role="list">
                <li class="process-step reveal-item" style="--reveal-delay: 80ms">
                    <div class="step-number" aria-hidden="true">01</div>
                    <h3 class="step-title">Discovery</h3>
                    <p class="step-description">
                        We learn your business goals, constraints, and priorities in a focused first session.
                    </p>
                </li>
                <li class="process-step reveal-item" style="--reveal-delay: 160ms">
                    <div class="step-number" aria-hidden="true">02</div>
                    <h3 class="step-title">Solution Design</h3>
                    <p class="step-description">
                        We propose an architecture and delivery approach tailored to your context.
                    </p>
                </li>
                <li class="process-step reveal-item" style="--reveal-delay: 240ms">
                    <div class="step-number" aria-hidden="true">03</div>
                    <h3 class="step-title">Build &amp; Iterate</h3>
                    <p class="step-description">
                        We deliver working software in short cycles, adjusting as you give feedback.
                    </p>
                </li>
                <li class="process-step reveal-item" style="--reveal-delay: 320ms">
                    <div class="step-number" aria-hidden="true">04</div>
                    <h3 class="step-title">Handover &amp; Support</h3>
                    <p class="step-description">
                        We document, transfer knowledge, and remain available for ongoing support.
                    </p>
                </li>
            </ol>
        </div>
    </section>

    <section id="contact" class="contact-cta-section" aria-labelledby="contact-heading">
        <div class="contact-cta-inner">
            <h2 id="contact-heading" class="contact-cta-heading reveal-item" style="--reveal-delay: 0ms">
                Ready to work together?
            </h2>
            <p class="contact-cta-sub reveal-item" style="--reveal-delay: 80ms">
                @(siteProps?.Name ?? "We") tailor every engagement to your business goals. Let's start a conversation.
            </p>
            @if (!string.IsNullOrWhiteSpace(siteProps?.Email))
            {
                <a href="mailto:@siteProps.Email"
                   class="btn btn-cta reveal-item"
                   style="--reveal-delay: 160ms"
                   aria-label="Email @siteProps.Email">
                    Email us at @siteProps.Email
                </a>
            }
        </div>
    </section>
</div>

<footer class="site-footer" role="contentinfo">
    <div class="footer-inner">
        <nav class="footer-nav" aria-label="Page sections">
            <a href="#services">Services</a>
            <a href="#how-we-work">How We Work</a>
            <a href="#contact">Contact</a>
        </nav>

        <div class="footer-social" aria-label="Social links">
            @if (!string.IsNullOrWhiteSpace(siteProps?.LinkedIn))
            {
                <a href="@($"https://www.linkedin.com/in/{siteProps.LinkedIn}")" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile">LinkedIn</a>
            }
            @if (!string.IsNullOrWhiteSpace(siteProps?.GitHub))
            {
                <a href="@($"https://github.com/{siteProps.GitHub}")" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">GitHub</a>
            }
            @if (!string.IsNullOrWhiteSpace(siteProps?.Twitter))
            {
                <a href="@($"https://x.com/{siteProps.Twitter}")" target="_blank" rel="noopener noreferrer" aria-label="Twitter profile">Twitter</a>
            }
            @if (!string.IsNullOrWhiteSpace(siteProps?.YouTube))
            {
                <a href="@($"https://www.youtube.com/@{siteProps.YouTube}")" target="_blank" rel="noopener noreferrer" aria-label="YouTube profile">YouTube</a>
            }
            @if (!string.IsNullOrWhiteSpace(siteProps?.Medium))
            {
                <a href="@($"https://medium.com/@{siteProps.Medium}")" target="_blank" rel="noopener noreferrer" aria-label="Medium profile">Medium</a>
            }
            @if (!string.IsNullOrWhiteSpace(siteProps?.DevDotTo))
            {
                <a href="@($"https://dev.to/{siteProps.DevDotTo}")" target="_blank" rel="noopener noreferrer" aria-label="dev.to profile">Dev.to</a>
            }
            @if (!string.IsNullOrWhiteSpace(siteProps?.Instagram))
            {
                <a href="@($"https://www.instagram.com/{siteProps.Instagram}")" target="_blank" rel="noopener noreferrer" aria-label="Instagram profile">Instagram</a>
            }
        </div>

        <p class="footer-copy">
            &copy; @DateTime.Now.Year @(siteProps?.Name ?? string.Empty). All rights reserved.
        </p>
    </div>
</footer>

<FloatingChatWidget />

@code {
    private SiteProperties? siteProps;
    private ServicesData? servicesData;

    protected override async Task OnInitializedAsync()
    {
        using var http = HttpClientFactory.CreateClient();
        var sitePropsTask = http.GetFromJsonAsync<SiteProperties>(Navigation.ToAbsoluteUri("/data/site-properties.json"));
        var servicesTask = http.GetFromJsonAsync<ServicesData>(Navigation.ToAbsoluteUri("/data/services.json"));

        await Task.WhenAll(sitePropsTask, servicesTask);

        siteProps = sitePropsTask.Result;
        servicesData = servicesTask.Result;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("reObserveRevealItems");
        }
    }
}
