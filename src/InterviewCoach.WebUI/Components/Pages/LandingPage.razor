@* Generated by GitHub Copilot on 2026-03-15 *@
@page "/"
@using InterviewCoach.WebUI.Services
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Bespoke Software Solutions - Interview Coach</PageTitle>

<div class="landing-container">
    <section id="hero" class="hero-section" aria-labelledby="hero-headline">
        <div class="hero-inner">
            <div class="hero-left reveal-item" style="--reveal-delay: 0ms">
                <h1 id="hero-headline" class="hero-headline">
                    @(siteProps?.Name ?? "Bespoke Software Solutions")
                </h1>
                <p class="hero-sub">
                    Tailored software consulting for your unique business needs.
                </p>
                <div class="hero-ctas">
                    <a href="#contact" class="btn btn-primary">Get in Touch</a>
                    <a href="#services" class="btn btn-secondary">Our Services</a>
                </div>
            </div>

            <div class="hero-right" aria-hidden="true">
                <div class="value-chip reveal-item" style="--reveal-delay: 160ms">
                    Generative AI integrated from day one
                </div>
                <div class="value-chip reveal-item" style="--reveal-delay: 240ms">
                    Over a decade of cross-industry experience
                </div>
                <div class="value-chip reveal-item" style="--reveal-delay: 320ms">
                    Cloud-native and scalable by default
                </div>
            </div>

            <div class="hero-accent-rule" aria-hidden="true"></div>
        </div>
    </section>

    <section id="services" class="services-section">
        <div class="services-container">
            <h2 class="services-title">Our Services</h2>
            <div class="services-grid">
                <div class="service-card">
                    <h3 class="service-name">Bespoke Software Solutions</h3>
                    <p class="service-description">Custom software tailored to your specific business requirements, designed with scalability and maintainability in mind.</p>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private SiteProperties? siteProps;

    protected override async Task OnInitializedAsync()
    {
        using var http = HttpClientFactory.CreateClient();
        siteProps = await http.GetFromJsonAsync<SiteProperties>(
            Navigation.ToAbsoluteUri("/data/site-properties.json"));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initReveal");
    }
}
