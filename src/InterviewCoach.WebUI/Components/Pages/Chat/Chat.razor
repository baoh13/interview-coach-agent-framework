@page "/interview"
@using System.ComponentModel
@using InterviewCoach.WebUI.Services
@inject ILogger<Chat> Logger
@inject FileUploadService FileUploadService

<PageTitle>Chat</PageTitle>

<ChatHeader OnNewChat="@HandleNewChat" />

<ChatMessageList Messages="@GetMessages()" InProgressMessage="@chatShell?.CurrentResponseMessage">
    <NoMessagesContent>
        <div>I'm your friendly interview coach. To get started, enter the link or text of your resume and job
            description.</div>
        <ChatCitation File="Example_Emergency_Survival_Kit.pdf" Quote="Sample citation" />
        <ChatCitation File="Example_GPS_Watch.pdf" Quote="Sample citation" />
        </NoMessagesContent>
    </ChatMessageList>

<div class="chat-container">
    <ChatSuggestions OnSelected="HandleSendMessage" @ref="@chatSuggestions" />
    <ChatInput OnSend="@HandleSendMessage" @ref="@chatInput" />
</div>

<ChatShell @ref="@chatShell" OnMessageAdded="@OnMessageAdded" />

@code {
    private ChatShell? chatShell;
    private ChatInput? chatInput;
    private ChatSuggestions? chatSuggestions;

    private IReadOnlyList<ChatMessage> GetMessages()
    {
        return chatShell?.Messages ?? [];
    }

    private async Task HandleSendMessage(ChatMessage userMessage)
    {
        chatSuggestions?.Clear();

        // If a file is attached, upload it and append the URL to the message
        var file = chatInput?.AttachedFile;
        if (file is not null)
        {
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                var url = await FileUploadService.UploadFileAsync(stream, file.Name, file.ContentType);
                var messageText = userMessage.Text?.Trim();
                var combined = string.IsNullOrEmpty(messageText)
                    ? $"I've attached my file: {url}"
                    : $"{messageText}\n[Attached file: {url}]";
                userMessage = new ChatMessage(ChatRole.User, combined);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to upload file {FileName}", file.Name);
            }
            finally
            {
                chatInput?.ClearAttachment();
            }
        }

        await chatShell!.AddUserMessageAsync(userMessage);
        await chatInput!.FocusAsync();
    }

    private async Task HandleNewChat()
    {
        await chatShell!.ResetConversationAsync();
        chatSuggestions?.Clear();
        await chatInput!.FocusAsync();
    }

    private Task OnMessageAdded(ChatMessage message)
    {
        if (message.Role == ChatRole.Assistant)
        {
            chatSuggestions?.Update(GetMessages());
        }

        return Task.CompletedTask;
    }
}
