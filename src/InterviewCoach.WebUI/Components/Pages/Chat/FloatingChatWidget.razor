@* Generated by GitHub Copilot on 2026-03-22 *@
@using System.Net.Http.Json
@using InterviewCoach.WebUI.Services

<div class="floating-chat-root" aria-live="polite">
    @if (!isOpen)
    {
        <button class="floating-chat-launcher" type="button" @onclick="HandleOpen" aria-label="Open baoh-assistant chat">
            💬
        </button>
    }
    else
    {
        <section class="floating-chat-panel" aria-label="baoh-assistant mini chat">
            <header class="floating-chat-header main-background-gradient">
                <h2>baoh-assistant</h2>
                <div class="floating-chat-actions">
                    <button type="button" @onclick="HandleHide" aria-label="Minimize chat">−</button>
                    <button type="button" @onclick="HandleHide" aria-label="Close chat">✕</button>
                </div>
            </header>

            <div class="floating-chat-messages">
                <ChatMessageList Messages="@GetMessages()" InProgressMessage="@chatShell?.CurrentResponseMessage">
                    <NoMessagesContent>
                        <div class="floating-chat-empty">Chat with baoh-assistant for quick help and guidance.</div>
                    </NoMessagesContent>
                </ChatMessageList>
            </div>

            <div class="floating-chat-input">
                <ChatInput OnSend="@HandleSendMessage" IncludeFileUpload="false" @ref="@chatInput" />
            </div>
        </section>
    }
</div>

<ChatShell @ref="@chatShell" WorkflowName="@WorkflowName" OnMessageAdded="@OnMessageAdded" />

@code {
    private const string GreetingPrefix = "Welcome to Baoh Consulting";
    private const string FallbackGreeting = "Welcome to Baoh Consulting. We help teams with bespoke software delivery, AI integration, and cloud solutions. What challenge are you trying to solve right now?";

    [Inject]
    private IHttpClientFactory HttpClientFactory { get; set; } = null!;

    [Inject]
    private NavigationManager Navigation { get; set; } = null!;

    [Parameter]
    public string? WorkflowName { get; set; }

    private ChatShell? chatShell;
    private ChatInput? chatInput;
    private bool isOpen;
    private bool hasAutoOpened;
    private bool hasSeededGreeting;
    private ChatMessage? seededGreeting;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasAutoOpened && IsLandingRoute())
        {
            hasAutoOpened = true;
            await Task.Delay(500);
            isOpen = true;
            await EnsureGreetingSeededAsync();
            StateHasChanged();
        }
    }

    private IReadOnlyList<ChatMessage> GetMessages()
    {
        var shellMessages = chatShell?.Messages ?? [];

        if (seededGreeting is null)
        {
            return shellMessages;
        }

        return HasAssistantMessageStartingWith(shellMessages, GreetingPrefix)
            ? shellMessages
            : [seededGreeting, .. shellMessages];
    }

    private void HandleOpen()
    {
        isOpen = true;
    }

    private void HandleHide()
    {
        isOpen = false;
    }

    private async Task HandleSendMessage(ChatMessage userMessage)
    {
        await chatShell!.AddUserMessageAsync(userMessage);
        await chatInput!.FocusAsync();
    }

    private Task OnMessageAdded(ChatMessage _)
    {
        return Task.CompletedTask;
    }

    private bool IsLandingRoute()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        return string.IsNullOrEmpty(relative) || string.Equals(relative, "/", StringComparison.Ordinal);
    }

    private async Task EnsureGreetingSeededAsync()
    {
        if (hasSeededGreeting || chatShell is null)
        {
            return;
        }

        hasSeededGreeting = true;
        seededGreeting = new ChatMessage(ChatRole.Assistant, await BuildGreetingAsync());

        if (HasAssistantMessageStartingWith(chatShell.Messages, GreetingPrefix))
        {
            seededGreeting = null;
        }
    }

    private async Task<string> BuildGreetingAsync()
    {
        try
        {
            using var http = HttpClientFactory.CreateClient();
            var siteTask = http.GetFromJsonAsync<SiteProperties>(Navigation.ToAbsoluteUri("/data/site-properties.json"));
            var servicesTask = http.GetFromJsonAsync<ServicesData>(Navigation.ToAbsoluteUri("/data/services.json"));

            await Task.WhenAll(siteTask!, servicesTask!);

            var site = siteTask.Result;
            var services = servicesTask.Result;

            var company = string.IsNullOrWhiteSpace(site?.Name) ? "Baoh Consulting" : site.Name.Trim();
            var serviceNames = services?.Cards
                .Select(c => c.Name?.Trim())
                .Where(name => string.IsNullOrWhiteSpace(name) == false)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Take(3)
                .ToArray() ?? [];

            var serviceSummary = serviceNames.Length > 0
                ? string.Join(", ", serviceNames)
                : "bespoke software delivery, AI integration, and cloud solutions";

            return $"Welcome to {company}. We help clients with {serviceSummary}. What challenge are you looking to solve right now?";
        }
        catch
        {
            return FallbackGreeting;
        }
    }

    private static bool HasAssistantMessageStartingWith(IEnumerable<ChatMessage> messages, string prefix)
    {
        return messages.Any(message =>
            message.Role == ChatRole.Assistant
            && message.Text is { Length: > 0 } text
            && text.StartsWith(prefix, StringComparison.Ordinal));
    }
}
