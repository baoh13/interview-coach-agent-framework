@* Generated by GitHub Copilot on 2026-03-22 *@

<div class="floating-chat-root" aria-live="polite">
    @if (!isOpen)
    {
        <button class="floating-chat-launcher" type="button" @onclick="HandleOpen" aria-label="Open Interview Coach chat">
            💬
        </button>
    }
    else
    {
        <section class="floating-chat-panel" aria-label="Interview Coach mini chat">
            <header class="floating-chat-header main-background-gradient">
                <h2>Interview Coach</h2>
                <div class="floating-chat-actions">
                    <button type="button" @onclick="HandleHide" aria-label="Minimize chat">−</button>
                    <button type="button" @onclick="HandleHide" aria-label="Close chat">✕</button>
                </div>
            </header>

            <div class="floating-chat-messages">
                <ChatMessageList Messages="@GetMessages()" InProgressMessage="@chatShell?.CurrentResponseMessage">
                    <NoMessagesContent>
                        <div class="floating-chat-empty">Ask interview questions, refine answers, and practice fast.</div>
                    </NoMessagesContent>
                </ChatMessageList>
            </div>

            <div class="floating-chat-input">
                <ChatInput OnSend="@HandleSendMessage" IncludeFileUpload="false" @ref="@chatInput" />
            </div>
        </section>
    }
</div>

<ChatShell @ref="@chatShell" OnMessageAdded="@OnMessageAdded" />

@code {
    private ChatShell? chatShell;
    private ChatInput? chatInput;
    private bool isOpen;
    private bool hasAutoOpened;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !hasAutoOpened)
        {
            hasAutoOpened = true;
            await Task.Delay(500);
            isOpen = true;
            StateHasChanged();
        }
    }

    private IReadOnlyList<ChatMessage> GetMessages()
    {
        return chatShell?.Messages ?? [];
    }

    private void HandleOpen()
    {
        isOpen = true;
    }

    private void HandleHide()
    {
        isOpen = false;
    }

    private async Task HandleSendMessage(ChatMessage userMessage)
    {
        await chatShell!.AddUserMessageAsync(userMessage);
        await chatInput!.FocusAsync();
    }

    private Task OnMessageAdded(ChatMessage _)
    {
        return Task.CompletedTask;
    }
}
